<launch>

<!-- Setup RTAB-Map with dual stereo cameras -->
<include file="$(find rtabmap_ros)/launch/stereo_mapping.launch">
<arg name="rtabmap_args"  value="--delete_db_on_start" />
<!-- Primary stereo pair (camera 0) -->
<arg name="left_image_topic"  value="/psvr_0/left/image_rect_color" />
<arg name="right_image_topic" value="/psvr_0/right/image_rect_color" />
<arg name="left_camera_info_topic" value="/psvr_0/left/camera_info" />
<arg name="right_camera_info_topic" value="/psvr_0/right/camera_info" />
<arg name="frame_id" value="psvr_0" />
<arg name="rviz" value="false" />
<arg name="approx_sync" value="false" />
<arg name="visual_odometry" value="true" />
<!-- Subscribe to additional stereo pair for enhanced mapping -->
<arg name="subscribe_stereo" value="true" />
<arg name="stereo_namespace" value="/psvr_1" />
</include>

<!-- Alternative: Manual RTAB-Map node configuration for full dual-camera control -->
<!-- Uncomment this section and comment the include above for advanced dual-camera SLAM -->
<!--
