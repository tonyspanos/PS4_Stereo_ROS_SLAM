-->



<!-- Start frame capturing from psvr cameras -->
<!-- Camera 0 -->
<node pkg="PSVR_cam_core" type="psvr_cam_publisher.py" name="psvr_cam_publisher_0">
  <param name="cam_number" value="0" />
  <param name="camera_namespace" value="psvr_0" />
</node>

<!-- Camera 1 -->
<node pkg="PSVR_cam_core" type="psvr_cam_publisher.py" name="psvr_cam_publisher_1">
  <param name="cam_number" value="1" />
  <param name="camera_namespace" value="psvr_1" />
</node>

<!-- Rotate the camera frames. -->
<arg name="pi/2" value="1.5707963267948966" />
<arg name="optical_rotate" value="0 0 0 -$(arg pi/2) 0 -$(arg pi/2)" />

<!-- Transform for camera 0 -->
<node pkg="tf" type="static_transform_publisher" name="camera_0_base_link"
        args="$(arg optical_rotate) base_link psvr_0 100" />

<!-- Transform for camera 1 -->
<node pkg="tf" type="static_transform_publisher" name="camera_1_base_link"
        args="0.1 0 0 -$(arg pi/2) 0 -$(arg pi/2) base_link psvr_1 100" />
        
<!-- Rotate the odometry frame. -->    
<arg name="odom_rotate" value="0 0 0 -$(arg pi/2) 0 -$(arg pi/2)" />
<node pkg="tf" type="static_transform_publisher" name="odom_base_link"
        args="$(arg optical_rotate) odom base_link 100" />  


<!-- Stereo image processing -->
<!-- Stereo processing for camera 0 -->
<node pkg="stereo_image_proc" type="stereo_image_proc" name="stereo_image_proc_0" ns="psvr_0">
<param name="approximate_sync" value="false" />
</node>

<!-- Stereo processing for camera 1 -->
<node pkg="stereo_image_proc" type="stereo_image_proc" name="stereo_image_proc_1" ns="psvr_1">
<param name="approximate_sync" value="false" />
</node>


<!-- Setup rqt_reconfigure to allow live stereo parameter testing (only tunes for rviz) -->
<node pkg="rqt_reconfigure" type="rqt_reconfigure" name="rqt_reconfigure">
</node>

</launch>
