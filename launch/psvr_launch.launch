<launch>

  <!-- ========================== Arguments ========================== -->
  <arg name="delete_db" default="true" doc="Delete RTAB-Map database on start" />
  <arg name="camera_baseline" default="0.03" doc="Distance between the two cameras (metres)" />
  <arg name="cam0_device" default="0" doc="/dev/video device index for forward camera" />
  <arg name="cam1_device" default="1" doc="/dev/video device index for backward camera" />

  <arg name="pi/2" value="1.5707963267948966" />
  <arg name="pi" value="3.141592653589793" />
  <arg name="optical_rotate" value="0 0 0 -$(arg pi/2) 0 -$(arg pi/2)" />

  <!-- Conditionally set rtabmap_args based on delete_db -->
  <arg name="rtabmap_args" value="--delete_db_on_start" if="$(arg delete_db)" />
  <arg name="rtabmap_args" value="" unless="$(arg delete_db)" />

  <!-- ========================== RTAB-Map ========================== -->
  <include file="$(find rtabmap_ros)/launch/stereo_mapping.launch">
    <arg name="rtabmap_args" value="$(arg rtabmap_args)" />
    <!-- Primary stereo pair — forward camera -->
    <arg name="left_image_topic" value="/psvr_0/left/image_rect_color" />
    <arg name="right_image_topic" value="/psvr_0/right/image_rect_color" />
    <arg name="left_camera_info_topic" value="/psvr_0/left/camera_info" />
    <arg name="right_camera_info_topic" value="/psvr_0/right/camera_info" />
    <arg name="frame_id" value="base_link" />
    <arg name="rviz" value="false" />
    <arg name="approx_sync" value="false" />
    <arg name="visual_odometry" value="true" />
    <arg name="subscribe_stereo" value="true" />
    <arg name="stereo_namespace" value="/psvr_1" />
  </include>

  <!-- ==================== Camera publishers ==================== -->
  <!-- Camera 0 — forward-facing -->
  <node pkg="PSVR_cam_core" type="psvr_cam_publisher.py" name="psvr_cam_publisher_0">
    <param name="cam_number" value="$(arg cam0_device)" />
    <param name="camera_namespace" value="psvr_0" />
  </node>

  <!-- Camera 1 — backward-facing -->
  <node pkg="PSVR_cam_core" type="psvr_cam_publisher.py" name="psvr_cam_publisher_1">
    <param name="cam_number" value="$(arg cam1_device)" />
    <param name="camera_namespace" value="psvr_1" />
  </node>

  <!-- ======================== TF tree ========================= -->
  <!--
  Physical layout (side view):
    [cam 0 forward]===3 cm===[backward cam 1]    mounted on a pole
  Both cameras share the same Y and Z position.
  Camera 0 faces forward (+X in base_link).
  Camera 1 faces backward (minus X), so it is rotated pi around Z.

  TF chain:
    odom > base_link > psvr_0_link > psvr_0  (optical frame)
                     > psvr_1_link > psvr_1  (optical frame)
-->

  <!-- Odometry → base_link (identity — the odom node fills this at runtime) -->
  <node pkg="tf" type="static_transform_publisher" name="odom_base_link"
    args="0 0 0 0 0 0 odom base_link 100" />

  <!-- Camera 0 sits at the base_link origin, facing forward -->
  <node pkg="tf" type="static_transform_publisher" name="base_to_cam0_link"
    args="0 0 0 0 0 0 base_link psvr_0_link 100" />
  <node pkg="tf" type="static_transform_publisher" name="cam0_optical"
    args="$(arg optical_rotate) psvr_0_link psvr_0 100" />

  <!-- Camera 1 is offset along X and rotated 180° (yaw = π) to face backward -->
  <node pkg="tf" type="static_transform_publisher" name="base_to_cam1_link"
    args="$(arg camera_baseline) 0 0 $(arg pi) 0 0 base_link psvr_1_link 100" />
  <node pkg="tf" type="static_transform_publisher" name="cam1_optical"
    args="$(arg optical_rotate) psvr_1_link psvr_1 100" />

  <!-- ================== Stereo image processing =============== -->
  <node pkg="stereo_image_proc" type="stereo_image_proc" name="stereo_image_proc_0" ns="psvr_0">
    <param name="approximate_sync" value="false" />
  </node>

  <node pkg="stereo_image_proc" type="stereo_image_proc" name="stereo_image_proc_1" ns="psvr_1">
    <param name="approximate_sync" value="false" />
  </node>

  <!-- Live stereo parameter tuning -->
  <node pkg="rqt_reconfigure" type="rqt_reconfigure" name="rqt_reconfigure" />

</launch>